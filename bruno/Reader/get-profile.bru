meta {
  name: Reader - Perfil
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/api/reader/profile
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

tests {
  test("Devuelve 200", function() {
    expect(res.status).to.equal(200);
  });

  test("Respuesta tiene email y role", function() {
    expect(res.getBody()).to.have.property("email");
    expect(res.getBody()).to.have.property("role");
  });
}